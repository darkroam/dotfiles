#!/bin/zsh

# Load the shell-independent environment used by login shells.
. "$HOME/.config/shell/profile"

unsetopt PROMPT_SP

# Start the graphical session only from the local first console.
if [[ $(tty) == /dev/tty1 ]] && [ -z "$SSH_CONNECTION" ] && [ -z "$DISPLAY" ]; then
    graphics_devices=(/dev/dri/card<->(N) /dev/fb<->(N))
    if (( ${#graphics_devices} )) && ! pgrep -x Xorg >/dev/null 2>&1; then
        export XINITRC="${XDG_CONFIG_HOME:-$HOME/.config}/x11/xinitrc"
        exec startx
    fi
    unset graphics_devices
fi

# Keep normal shells on recovery consoles and avoid garbled CJK text.
if [[ $(tty) == /dev/tty[2-9]* ]] && [ -z "$SSH_CONNECTION" ]; then
    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8
fi

# fbterm remains disabled because the current fbdev driver is unstable.

# Switch Escape and Caps Lock when passwordless sudo is available.
sudo -n loadkeys "${XDG_DATA_HOME:-$HOME/.local/share}/larbs/ttymaps.kmap" 2>/dev/null
