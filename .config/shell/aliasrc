#!/bin/sh

# Use neovim for vim if present.
[ -x "$(command -v nvim)" ] && alias vim="nvim" vimdiff="nvim -d"
alias nvim="$EDITOR"

# Use $XINITRC variable if file exists.
[ -f "$XINITRC" ] && alias startx="startx $XINITRC"

# Run selected system commands through sudo when they are available.
for command in mount umount sv pacman updatedb su shutdown poweroff reboot ; do
	command -v "$command" >/dev/null 2>&1 && alias "$command=sudo $command"
done; unset command


# Verbosity and settings that you pretty much just always are going to want.
alias \
	batt="cat /sys/class/power_supply/BAT?/capacity" \
	cp="cp -iv" \
	mv="mv -iv" \
	rm="rm -vI" \
	bc="bc -ql" \
	mkd="mkdir -pv" \
#	yt="youtube-dl --add-metadata -i" \
	yt="yt-dlp --embed-metadata -i" \
	yta="yt -x -f bestaudio/best" \
	ffmpeg="ffmpeg -hide_banner"

# Colorize commands when possible.
if [ "$(uname)" = "Darwin" ]; then
	alias \
		ls="ls -h" \
		sl="ls -h" \
		l.='ls -d .*' \
		ll='ls -hAlF' \
		ll.='ls -hAlFd .*' \
		pss='ps aux | grep -v grep | grep -i -e VSZ -e'
elif [ "$(expr substr $(uname -s) 1 5)" = "Linux" ]; then
	alias \
		ls="ls -hN --color=auto --group-directories-first" \
		sl="ls -hN --color=auto --group-directories-first" \
		l.='ls -d .* --color=auto --group-directories-first' \
		ll='ls -hAlF --group-directories-first' \
		ll.='ls -hAlFd .* --group-directories-first' \
		diff="diff --color=auto" \
		pss='ps auxf | grep -v grep | grep -i -e VSZ -e'
fi

alias \
	grep="grep --color=auto" \
	ccat="highlight --out-format=ansi" \
	ip="ip -color=auto" \
	which='command -v' \
	..='cd ..' \
	...='cd ..\..'

# These common commands are just too long! Abbreviate them.
alias \
	ka="killall" \
	g="git" \
	gua='git remote | xargs -L1 git push --all' \
	c='/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME' \
	trem="transmission-remote" \
	YT="youtube-viewer" \
	sdn="sudo shutdown -h now" \
	e="emacs" \
	v="$EDITOR" \
	calcurse='calcurse -D ~/.config/calcurse' \
	x='nsxiv -ft *' \
	z="zathura"

# Shared Git helpers. Keep gs for the system Ghostscript command.
alias \
	gco='git checkout' \
	gd='git --no-pager diff' \
	gst='git --no-pager status' \
	gss='git --no-pager status -s' \
	gsh='git --no-pager show' \
	gpt='git push origin --tags'

unalias gam 2>/dev/null || true

gpo() {
	local branch
	branch=$(git symbolic-ref --short -q HEAD) || return 1
	git push origin "$branch"
}

gpl() {
	local branch
	branch=$(git symbolic-ref --short -q HEAD) || return 1
	git pull origin "$branch" --ff-only
}

glt() {
	git tag -n --sort=taggerdate | tail -n "${1:-10}"
}

gat() {
	[ "$#" -eq 2 ] || return 2
	git tag -a "$1" -m "$2"
}

gam() {
	git add --all && git commit -m "$*"
}

gitlog() {
	[ -n "${1:-}" ] || return 2
	git --no-pager log --date=format:'%Y-%m-%d %H:%M' --pretty="tformat:$1" --graph -n "${2:-10}"
}

gll() {
	gitlog "%C(${gitHashColor:-magenta})%h %C(${gitContentColor:-cyan})%s%Creset" "${1:-10}"
}

glll() {
	gitlog "%C(${gitHashColor:-magenta})%h %C(${gitDateColor:-yellow})%cd %C(${gitAuthorColor:-blue})%cn: %C(${gitContentColor:-cyan})%s%Creset" "${1:-10}"
}

# Mirror the Git helpers above for the bare configuration repository.
cfg_git() {
	/usr/bin/git --git-dir="$HOME/.cfg/" --work-tree="$HOME" "$@"
}

cgco() {
	cfg_git checkout "$@"
}

cgpo() {
	local branch
	branch=$(cfg_git symbolic-ref --short -q HEAD) || return 1
	cfg_git push origin "$branch"
}

cgpl() {
	local branch
	branch=$(cfg_git symbolic-ref --short -q HEAD) || return 1
	cfg_git pull origin "$branch" --ff-only
}

cgd() {
	cfg_git --no-pager diff "$@"
}

cgst() {
	cfg_git --no-pager status "$@"
}

cgss() {
	cfg_git --no-pager status -s "$@"
}

cgsh() {
	cfg_git --no-pager show "$@"
}

cgpt() {
	cfg_git push origin --tags "$@"
}

cglt() {
	cfg_git tag -n --sort=taggerdate | tail -n "${1:-10}"
}

cgat() {
	[ "$#" -eq 2 ] || return 2
	cfg_git tag -a "$1" -m "$2"
}

cgam() {
	cfg_git add --all && cfg_git commit -m "$*"
}

cgitlog() {
	[ -n "${1:-}" ] || return 2
	cfg_git --no-pager log --date=format:'%Y-%m-%d %H:%M' --pretty="tformat:$1" --graph -n "${2:-10}"
}

cgll() {
	cgitlog "%C(${gitHashColor:-magenta})%h %C(${gitContentColor:-cyan})%s%Creset" "${1:-10}"
}

cglll() {
	cgitlog "%C(${gitHashColor:-magenta})%h %C(${gitDateColor:-yellow})%cd %C(${gitAuthorColor:-blue})%cn: %C(${gitContentColor:-cyan})%s%Creset" "${1:-10}"
}

# Package management. All aliases use the same p-prefix across distributions:
# p: manager, pu: update, pi: install, pr: remove, pse: search,
# pp: package information, pl: installed packages, pc: cleanup.
if command -v apt >/dev/null 2>&1; then
	alias p='sudo apt'
	alias pu='sudo apt update && sudo apt upgrade'
	alias pi='sudo apt install'
	alias pr='sudo apt remove'
	alias pse='apt search'
	alias pp='apt show'
	alias pl='apt list --installed'
	alias pc='sudo apt autoremove --purge'
elif command -v pacman >/dev/null 2>&1; then
	alias p='sudo pacman'
	alias pu='sudo pacman -Syu'
	alias pi='sudo pacman -S'
	alias pr='sudo pacman -Rns'
	alias pse='pacman -Ss'
	alias pp='pacman -Qi'
	alias pl='pacman -Q'
	alias pc='sudo pacman -Rns $(pacman -Qtdq)'
elif command -v xbps-install >/dev/null 2>&1; then
	alias p='sudo xbps-install'
	alias pu='sudo xbps-install -Syu'
	alias pi='sudo xbps-install'
	alias pr='sudo xbps-remove -R'
	alias pse='xbps-query -Rs'
	alias pp='xbps-query -R'
	alias pl='xbps-query -l'
	alias pc='sudo xbps-remove -Oo'
elif command -v emerge >/dev/null 2>&1; then
	alias p='sudo emerge'
	alias pu='sudo emerge-webrsync && sudo emerge --ask -uDN @world'
	alias pi='sudo emerge'
	alias pr='sudo emerge --ask --unmerge'
	alias pse='emerge --search'
	alias pp='emerge -pv'
	alias pl='find /var/db/pkg -mindepth 2 -maxdepth 2 -type d -printf "%P\n"'
	alias pc='sudo emerge --depclean'
fi

# Give each MPV instance a unique socket so pauseallmpv can control it.
mpv() {
	mpv_socket_dir="${XDG_RUNTIME_DIR:-/tmp}/mpvSockets"
	if ! mkdir -p "$mpv_socket_dir"; then
		unset mpv_socket_dir
		return 1
	fi
	command mpv --input-ipc-server="$mpv_socket_dir/mpv-$$-$(date +%s%N)" "$@"
	mpv_status=$?
	unset mpv_socket_dir
	return "$mpv_status"
}

# Some other stuff
alias \
	lf="lfub" \
	magit="nvim -c MagitOnly" \
	ref="shortcuts >/dev/null; source ${XDG_CONFIG_HOME:-$HOME/.config}/shell/shortcutrc ; source ${XDG_CONFIG_HOME:-$HOME/.config}/shell/zshnameddirrc"
#	tmux="tmux -f ${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf"

# Customization
alias \
	lg="lazygit" \
	t="tldr" \
  cc-switch-cli='~/.local/bin/cc-switch'

local_aliasrc="${XDG_CONFIG_HOME:-$HOME/.config}/shell/aliasrc.local"
[ -r "$local_aliasrc" ] && . "$local_aliasrc"
unset local_aliasrc
