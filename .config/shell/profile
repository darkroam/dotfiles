[ ! -f ${XDG_CONFIG_HOME:-$HOME/.config}/shell/shortcutrc ] && shortcuts >/dev/null 2>&1 &

# Start graphical server on tty1 if not already running.
# Prefer Xorg now that innogpu provides /dev/dri/card0.  Do not exec fbterm here:
# if fbterm cannot attach to the DRM framebuffer, the login shell exits and it
# looks like a failed terminal login.
if [[ $(tty) == /dev/tty1 ]] && [ -z "$SSH_CONNECTION" ] && [ -z "$DISPLAY" ]; then
    if [ -e /dev/dri/card0 ] && ! pgrep -x Xorg >/dev/null 2>&1; then
        export XINITRC="${XDG_CONFIG_HOME:-$HOME/.config}/x11/xinitrc"
        exec startx
    fi
fi

# Keep normal shell on TTY2-TTY6 for recovery/debugging.
# Set English locale on non-TTY1 consoles to avoid garbled CJK text.
if [[ $(tty) == /dev/tty[2-9]* ]] && [ -z "$SSH_CONNECTION" ]; then
    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8
fi

# fbterm disabled: innogpu fbdev driver causes segfault (fbterm 1.7-5 + Debian 13).
# The crash leaves terminal state broken — VT switching fails, sudo/reads hang.
# Keep the shell native; fbterm can be started manually if needed.
# if [[ $(tty) == /dev/tty[2-6] ]] && [ -z "$SSH_CONNECTION" ]; then
#     if [ -e /dev/fb0 ] && command -v fbterm >/dev/null 2>&1; then
#         export LANG=zh_CN.UTF-8
#         export LC_ALL=zh_CN.UTF-8
#         fbterm || true
#     fi
# fi

# Switch escape and caps if tty and no passwd required:
sudo -n loadkeys ${XDG_DATA_HOME:-$HOME/.local/share}/larbs/ttymaps.kmap 2>/dev/null

. "$HOME/.local/bin/env"
