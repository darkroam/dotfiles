#!/bin/sh

# profile file. Runs on login. Environmental variables are set here.

# If you don't plan on reverting to bash, you can remove the link in ~/.profile
# to clean up.

# Add local commands, including grouped scripts such as statusbar modules.
local_bin_paths=$(find "$HOME/.local/bin" -type d -exec printf '%s:' {} + 2>/dev/null)
local_bin_paths=${local_bin_paths%:}
[ -n "$local_bin_paths" ] && PATH="$PATH:$local_bin_paths"
export PATH
