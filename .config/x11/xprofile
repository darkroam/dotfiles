#!/bin/sh

# This file runs when a DM logs you into a graphical session.
# If you use startx/xinit like a Chad, this file will also be sourced.

# This file's true location is in ~/.config/xprofile and a link exists to it in
# ~/.xprofile. If you do not use a DM, you may remove the link to it to have a
# cleaner home.

# Fix Gnome Apps Slow  Start due to failing services
# Add this when you include flatpak in your system
dbus-update-activation-environment --systemd DBUS_SESSION_BUS_ADDRESS DISPLAY XAUTHORITY

# Display-manager sessions may not load the shell profile.
case ":$PATH:" in
	*:"$HOME/.local/bin":*) ;;
	*) PATH="$HOME/.local/bin:$PATH" ;;
esac
export PATH

command -v dbus-launch >/dev/null 2>&1 && eval "$(dbus-launch --sh-syntax --exit-with-session)"

# Select one input-method engine for both environment variables and startup.
IM_NAME=""
IM_COMMAND=""
IM_MODULE=""
if command -v fcitx5 >/dev/null 2>&1; then
	IM_NAME="fcitx5"
	IM_COMMAND="$(command -v fcitx5)"
	IM_MODULE="fcitx"
elif command -v fcitx >/dev/null 2>&1; then
	IM_NAME="fcitx"
	IM_COMMAND="$(command -v fcitx)"
	IM_MODULE="fcitx"
elif command -v ibus >/dev/null 2>&1; then
	IM_NAME="ibus"
	IM_COMMAND="$(command -v ibus)"
	IM_MODULE="ibus"
fi

if [ -n "$IM_NAME" ]; then
	export IM_NAME IM_COMMAND
	export GTK_IM_MODULE="$IM_MODULE"
	export QT_IM_MODULE="$IM_MODULE"
	export XMODIFIERS="@im=$IM_MODULE"
fi
unset IM_MODULE

alias setproxy="export http_proxy=http://127.0.0.1:7897 https_proxy=http://127.0.0.1:7897 all_proxy=socks5://127.0.0.1:7897 HTTP_PROXY=http://127.0.0.1:7897 HTTPS_PROXY=http://127.0.0.1:7897 ALL_PROXY=socks5://127.0.0.1:7897"
alias unsetproxy="unset http_proxy https_proxy all_proxy HTTP_PROXY HTTPS_PROXY ALL_PROXY"
alias ip="curl -i http://ip.cn"

export GO111MODULE=on
export GOPROXY=https://goproxy.cn,direct

command -v xrandr >/dev/null 2>&1 && xrandr --dpi 96		# Set DPI. User may want to use a larger number for larger screens.
command -v setbg >/dev/null 2>&1 && setbg			# set the background with the `setbg` script
xresources="${XDG_CONFIG_HOME:-$HOME/.config}/x11/xresources"
if command -v xrdb >/dev/null 2>&1 && [ -f "$xresources" ]; then
	xrdb -merge "$xresources"
fi
if command -v xrdb >/dev/null 2>&1 && [ -f "${XDG_CACHE_HOME:-$HOME/.cache}/wal/colors.Xresources" ]; then
	xrdb -merge "${XDG_CACHE_HOME:-$HOME/.cache}/wal/colors.Xresources" & xrdbpid=$!  # wal colors via Xresources
fi
command -v remaps >/dev/null 2>&1 && remaps &		# run the remaps script, switching caps/esc and more; check it for more info
command -v xset >/dev/null 2>&1 && xset r rate 300 50 &	# Speed xrate up
case "$IM_NAME" in
	fcitx|fcitx5) "$IM_COMMAND" -d ;;
	ibus) "$IM_COMMAND" daemon -drx ;;
esac

# Set this only when a driver uses nonstandard or changing names for the internal panel.
export XDISPLAY_INTERNAL_OUTPUTS="eDP-1 DP-1"
if command -v innogpu-restore-dp1-mode-x11 >/dev/null 2>&1; then
	XDISPLAY_RESTORE_COMMAND=${XDISPLAY_RESTORE_COMMAND:-innogpu-restore-dp1-mode-x11}
	export XDISPLAY_RESTORE_COMMAND
fi
command -v xdisplay.sh >/dev/null 2>&1 && xdisplay.sh --watch &
picom_cmd="${PICOM_BIN:-$(command -v picom 2>/dev/null)}"
if [ -n "$picom_cmd" ] && [ -x "$picom_cmd" ]; then
	mkdir -p "${XDG_CACHE_HOME:-$HOME/.cache}"
	if ! pidof -s picom >/dev/null; then
		if command -v setsid >/dev/null 2>&1; then
			setsid -f "$picom_cmd" --config "${XDG_CONFIG_HOME:-$HOME/.config}/x11/picom.conf" --log-level=warn --log-file "${XDG_CACHE_HOME:-$HOME/.cache}/picom.log" >/dev/null 2>&1
		else
			nohup "$picom_cmd" --config "${XDG_CONFIG_HOME:-$HOME/.config}/x11/picom.conf" --log-level=warn --log-file "${XDG_CACHE_HOME:-$HOME/.cache}/picom.log" >/dev/null 2>&1 &
		fi
	fi
elif command -v xcompmgr >/dev/null 2>&1; then
	if ! pidof -s xcompmgr >/dev/null; then
		if command -v setsid >/dev/null 2>&1; then
			setsid -f xcompmgr >/dev/null 2>&1
		else
			nohup xcompmgr >/dev/null 2>&1 &
		fi
	fi
fi

# PipeWire is managed by its systemd user services. Missing optional programs
# are harmless here because failures are silenced by the loop below.
autostart="mpd dunst unclutter"
for program in $autostart; do
	pidof -s "$program" || "$program" &
done >/dev/null 2>&1

# Ensure that xrdb has finished running before moving on to start the WM/DE.
[ -n "$xrdbpid" ] && wait "$xrdbpid"
unset xresources

