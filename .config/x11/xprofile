#!/bin/sh

# This file runs when a DM logs you into a graphical session.
# If you use startx/xinit like a Chad, this file will also be sourced.

# This file's true location is in ~/.config/xprofile and a link exists to it in
# ~/.xprofile. If you do not use a DM, you may remove the link to it to have a
# cleaner home.

# Fix Gnome Apps Slow  Start due to failing services
# Add this when you include flatpak in your system
dbus-update-activation-environment --systemd DBUS_SESSION_BUS_ADDRESS DISPLAY XAUTHORITY

command -v dbus-launch >/dev/null 2>&1 && eval "$(dbus-launch --sh-syntax --exit-with-session)"
export GTK_IM_MODULE=fcitx
export QT_IM_MODULE=fcitx
export XMODIFIERS="@im=fcitx"

alias setproxy="export ALL_PROXY=http://127.0.0.1:10080"
#alias setproxy="export ALL_PROXY=socks5://127.0.0.1:1080"
alias unsetproxy="unset ALL_PROXY"
alias ip="curl -i http://ip.cn"
alias fcitx="fcitx5"

export GO111MODULE=on
export GOPROXY=https://goproxy.cn,direct

command -v xrandr >/dev/null 2>&1 && xrandr --dpi 96		# Set DPI. User may want to use a larger number for larger screens.
command -v setbg >/dev/null 2>&1 && setbg &			# set the background with the `setbg` script
#xrdb ${XDG_CONFIG_HOME:-$HOME/.config}/x11/xresources & xrdbpid=$!   # Uncomment to use Xresources colors/settings on startup
xrdb -merge ${XDG_CACHE_HOME:-$HOME/.cache}/wal/colors.Xresources & xrdbpid=$!  # wal colors via Xresources
command -v remaps >/dev/null 2>&1 && remaps &		# run the remaps script, switching caps/esc and more; check it for more info
command -v xset >/dev/null 2>&1 && xset r rate 300 50 &	# Speed xrate up
command -v fcitx >/dev/null 2>&1 && fcitx &

command -v xdisplay.sh >/dev/null 2>&1 && xdisplay.sh &
picom_cmd="${PICOM_BIN:-$(command -v picom 2>/dev/null)}"
if [ -n "$picom_cmd" ] && [ -x "$picom_cmd" ]; then
	mkdir -p "${XDG_CACHE_HOME:-$HOME/.cache}"
	if ! pidof -s picom >/dev/null; then
		if command -v setsid >/dev/null 2>&1; then
			setsid -f "$picom_cmd" --config "${XDG_CONFIG_HOME:-$HOME/.config}/x11/picom.conf" --log-level=warn --log-file "${XDG_CACHE_HOME:-$HOME/.cache}/picom.log" >/dev/null 2>&1
		else
			nohup "$picom_cmd" --config "${XDG_CONFIG_HOME:-$HOME/.config}/x11/picom.conf" --log-level=warn --log-file "${XDG_CACHE_HOME:-$HOME/.cache}/picom.log" >/dev/null 2>&1 &
		fi
	fi
elif command -v xcompmgr >/dev/null 2>&1; then
	if ! pidof -s xcompmgr >/dev/null; then
		if command -v setsid >/dev/null 2>&1; then
			setsid -f xcompmgr >/dev/null 2>&1
		else
			nohup xcompmgr >/dev/null 2>&1 &
		fi
	fi
fi

autostart="mpd dunst unclutter pipewire"
for program in $autostart; do
	pidof -s "$program" || "$program" &
done >/dev/null 2>&1

# Ensure that xrdb has finished running before moving on to start the WM/DE.
[ -n "$xrdbpid" ] && wait "$xrdbpid"

