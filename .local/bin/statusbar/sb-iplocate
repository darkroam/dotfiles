#!/bin/sh

# Gets your public ip address checks which country you are in and
# displays that information in the statusbar
#
# https://www.maketecheasier.com/ip-address-geolocation-lookups-linux/

command -v geoiplookup >/dev/null 2>&1 || exit 0

addr="$(curl -fsS --max-time 2 https://ifconfig.me)" || exit 0
country="$(geoiplookup "$addr" | sed 's/.*, //')"
[ -n "$country" ] || exit 0

grep -F "flag: $country" "${XDG_DATA_HOME:-$HOME/.local/share}/larbs/emoji" | sed "s/flag: //;s/;.*//"
