#!/bin/sh

# Displays the number of upgradeable APT packages. Package lists are refreshed
# by the checkup script or the system's APT timers.

updates="$(apt list --upgradable 2>/dev/null | sed 1d)"

case $BLOCK_BUTTON in
	1) setsid -f "$TERMINAL" -e sb-popupgrade ;;
	2) if [ -n "$updates" ]; then notify-send "$updates"; else notify-send "📦 Package Check" "No updates available."; fi ;;
	3) notify-send "🎁 Upgrade module" "📦: number of upgradable packages
- Left click to upgrade packages
- Middle click to show upgradable packages" ;;
	6) "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

count="$(printf '%s\n' "$updates" | sed '/^$/d' | wc -l)"
[ "$count" -gt 0 ] && printf '📦%s\n' "$count"
