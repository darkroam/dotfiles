#!/usr/bin/env python3

import os
import shutil
import subprocess
import sys


def selection_path(selection):
    selection = selection.rstrip("\n")
    if os.path.exists(selection):
        return selection, None

    path, separator, remainder = selection.partition(":")
    if separator and os.path.exists(path):
        line, _, _ = remainder.partition(":")
        return path, line if line.isdigit() else None

    return selection, None


def run(command):
    subprocess.run(command, check=False)


def preview_text(path, line):
    bat = shutil.which("bat") or shutil.which("batcat")
    if bat:
        command = [bat, "--style=numbers", "--color=always"]
        if line:
            command.extend(["--highlight-line", line])
        run(command + ["--", path])
    else:
        run(["sed", "-n", "1,200p", "--", path])


def preview(path, line):
    lower_path = path.lower()

    if os.path.isdir(path):
        run(["ls", "-la", "--", path])
    elif lower_path.endswith(".zip") and shutil.which("unzip"):
        run(["unzip", "-l", path])
    elif lower_path.endswith(".rar") and shutil.which("unrar"):
        run(["unrar", "l", path])
    elif lower_path.endswith(".torrent") and shutil.which("transmission-show"):
        run(["transmission-show", path])
    elif lower_path.endswith((".html", ".htm", ".xhtml")) and shutil.which("w3m"):
        run(["w3m", "-dump", path])
    else:
        preview_text(path, line)


if __name__ == "__main__":
    selection = sys.stdin.readline()
    if selection:
        preview(*selection_path(selection))
