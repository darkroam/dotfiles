#!/bin/sh

# Podboat sucks. This script replaces it.
# It reads the newsboat queue, queuing downloads with taskspooler.
# It also removes the junk from extensions.
queuefile="${XDG_DATA_HOME:-$HOME/.local/share}/newsboat/queue"
[ -f "$queuefile" ] || exit 0
ifinstalled curl || exit 1

pending="$(mktemp "${queuefile}.XXXXXX")" || exit 1
trap 'rm -f "$pending"' 0 HUP INT QUIT TERM

while IFS= read -r line || [ -n "$line" ]; do
	[ -z "$line" ] && continue
	url="${line%%[	 ]*}"
	qndl "$url" "curl -LO" || printf '%s\n' "$line" >> "$pending"
done < "$queuefile"

mv "$pending" "$queuefile"
