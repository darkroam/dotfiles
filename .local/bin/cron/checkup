#!/bin/sh

# Refreshes the APT package index and reports available updates.

notify-send "📦 Package Check" "Checking for package updates..."

if ! sudo apt update; then
	notify-send "📦 Package Check" "Unable to refresh APT package lists.

Check your internet connection, sudo access, or run pu manually to see errors."
	exit 1
fi

pkill -RTMIN+8 "${STATUSBAR:-dwmblocks}"

if apt list --upgradable 2>/dev/null | sed 1d | grep -q .
then
	notify-send "🎁 Package Check" "Updates available. Run pu to upgrade."
else
	notify-send "📦 Package Check" "Package lists are current."
fi
