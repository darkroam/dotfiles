#!/bin/sh

# This script compiles or runs another finishing operation on a document. It
# can be called directly or from an editor mapping.
#
# Compiles .tex. groff (.mom, .ms), .rmd, .md, .org.  Opens .sent files as sent
# presentations. Runs scripts based on extension or shebang.
#
# TeX documents may declare their root and engine in the first 20 lines:
# % !TeX root = ../main.tex
# % !TeX program = xelatex

[ "$#" -eq 1 ] && [ -f "$1" ] || {
	printf '%s\n' "Provide an existing source file." >&2
	exit 1
}

file="$(readlink -f -- "$1")" || exit 1
dir=${file%/*}
base="${file%.*}"
ext="${file##*.}"

cd "$dir" || exit 1

tex_program() {
	[ -r "$1" ] || {
		printf 'compiler: cannot read %s\n' "$1" >&2
		return 2
	}
	LC_ALL=C awk -v source="$1" '
		function trim(value) {
			sub(/^[[:space:]]+/, "", value)
			sub(/[[:space:]]+$/, "", value)
			return value
		}
		function fail(message, status) {
			printf "compiler: %s in %s\n", message, source > "/dev/stderr"
			error = status
			exit
		}
		BEGIN { quote = sprintf("%c", 39) }
		NR > 20 { exit }
		/^[[:space:]]*%[[:space:]]*![[:space:]]*[Tt][Ee][Xx][[:space:]]+[Pp][Rr][Oo][Gg][Rr][Aa][Mm][[:space:]]*=/ {
			line = $0
			sub(/\r$/, "", line)
			sub(/^[^=]*=[[:space:]]*/, "", line)
			line = trim(line)
			if (line == "")
				fail("empty TeX program directive", 64)
			first = substr(line, 1, 1)
			last = substr(line, length(line), 1)
			if (first == "\"" || first == quote || last == "\"" || last == quote) {
				if (first != last || (first != "\"" && first != quote))
					fail("unmatched quote in TeX program directive", 64)
				line = substr(line, 2, length(line) - 2)
				if (line == "")
					fail("empty TeX program directive", 64)
			}
			line = tolower(line)
			if (!found) {
				program = line
				found = 1
			} else if (line != program) {
				fail("conflicting TeX program directives", 65)
			}
		}
		END {
			if (error)
				exit error
			if (!found)
				exit 1
			print program
		}
	' "$1"
}

compile_tex() {
	command -v texroot >/dev/null 2>&1 || {
		printf '%s\n' "compiler: texroot is required for TeX files." >&2
		return 1
	}
	command -v latexmk >/dev/null 2>&1 || {
		printf '%s\n' "compiler: latexmk is required for TeX files." >&2
		return 1
	}

	root=$(texroot "$file") || return 1
	root_dir=${root%/*}
	root_name=${root##*/}
	if program=$(tex_program "$root"); then
		:
	else
		status=$?
		[ "$status" -eq 1 ] || return "$status"
		program=pdflatex
		head -n 5 "$root" | grep -qi xelatex && program=xelatex
	fi

	case "$program" in
		pdflatex) mode=-pdf ;;
		xelatex) mode=-xelatex ;;
		lualatex) mode=-lualatex ;;
		*)
			printf 'compiler: unsupported TeX program in %s: %s\n' "$root" "$program" >&2
			return 1
			;;
	esac
	command -v "$program" >/dev/null 2>&1 || {
		printf 'compiler: TeX program is not installed: %s\n' "$program" >&2
		return 1
	}

	(
		cd "$root_dir" || exit 1
		set -- "$mode" -outdir=.
		latexmk_help=$(latexmk -norc -help 2>&1)
		case "$latexmk_help" in *-out2dir*) set -- "$@" -out2dir=. ;; esac
		latexmk "$@" -interaction=nonstopmode -halt-on-error \
			-file-line-error -synctex=1 "./$root_name"
	) || return 1

	[ -f "$root_dir/${root_name%.*}.pdf" ] || {
		printf 'compiler: expected output PDF was not created: %s\n' \
			"$root_dir/${root_name%.*}.pdf" >&2
		return 1
	}
}

case "$ext" in
	# Try to keep these cases in alphabetical order.
	[0-9]) preconv "$file" | refer -PS -e | groff -mandoc -T pdf > "$base".pdf ;;
	c) cc "$file" -o "$base" && "$base" ;;
	cpp) g++ "$file" -o "$base" && "$base" ;;
	cs) mcs "$file" && mono "$base".exe ;;
	go) go run "$file" ;;
	h) sudo make install ;;
	java) javac -d classes "$file" && java -cp classes "${1%.*}" ;;
	m) octave "$file" ;;
	md)	if  [ -x "$(command -v lowdown)" ]; then
			lowdown --parse-no-intraemph "$file" -Tms | groff -mpdfmark -ms -kept > "$base".pdf
		elif [ -x "$(command -v groffdown)" ]; then
			groffdown -i "$file" | groff > "$base.pdf"
		else
			pandoc -t ms --highlight-style=kate -s -o "$base".pdf "$file"
		fi ; ;;
	mom) preconv "$file" | refer -PS -e | groff -mom -kept -T pdf > "$base".pdf ;;
	ms) preconv "$file" | refer -PS -e | groff -me -ms -kept -T pdf > "$base".pdf ;;
	org) emacs "$file" --batch -u "$USER" -f org-latex-export-to-pdf ;;
	py) python "$file" ;;
	[rR]md) Rscript -e "rmarkdown::render('$file', quiet=TRUE)" ;;
	rs) cargo build ;;
	sass) sassc -a "$file" "$base.css" ;;
	scad) openscad -o "$base".stl "$file" ;;
	sent) setsid -f sent "$file" 2>/dev/null ;;
	[Tt][Ee][Xx]) compile_tex ;;
	*) sed -n '/^#!/s/^#!//p; q' "$file" | xargs -r -I % "$file" ;;
esac
