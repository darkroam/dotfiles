#!/bin/sh

# MPV instances started through the shell function use these Unix sockets.
# This command pauses every matching instance.

socket_dir="${XDG_RUNTIME_DIR:-/tmp}/mpvSockets"
for socket in "$socket_dir"/*; do
	[ -S "$socket" ] || continue
	printf '%s\n' '{ "command": ["set_property", "pause", true] }' | socat - "$socket"
done
